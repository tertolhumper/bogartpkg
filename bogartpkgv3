#!/bin/bash
# bogartpkg — Bogart Linux package manager
export PKG_CONFIG_PATH="/usr/lib/pkgconfig:/usr/lib64/pkgconfig:/usr/local/lib/pkgconfig:/usr/share/pkgconfig"
export PATH="$PATH:/usr/local/go/bin"
export CMAKE_PREFIX_PATH="/opt/qt6:/opt/qt5"
# /usr/local/bin/bogartpkg
set -euo pipefail
# Configuration
PKGDIR="/etc/bogartpkg/packages.d"
BUILDROOT="/var/tmp/bogartpkg"
SRCDIR="/sources"
LOGFILE="/var/log/bogartpkg/bogartpkg.log"
DRYRUN=""
# Colors 
RED='\033[0;31m'; GRN='\033[0;32m'; YLW='\033[1;33m'
BLU='\033[0;34m'; CYN='\033[0;36m'; NC='\033[0m'
# Helpers 
die()  { echo -e "${RED}[ERROR]${NC} $*" >&2; exit 1; }
info() { echo -e "${BLU}[INFO]${NC}  $*"; }
ok()   { echo -e "${GRN}[ OK ]${NC}  $*"; }
warn() { echo -e "${YLW}[WARN]${NC}  $*"; }
step() { echo -e "${CYN}[STEP]${NC}  $*"; }
dry()  { echo -e "${YLW}[DRYRUN]${NC} $*"; }

run() {
    if [ -n "$DRYRUN" ]; then
        dry "  $*"
    else
        eval "$@"
    fi
}
require_root() {
    [ "$(id -u)" -eq 0 ] || die "bogartpkg must be run as root"
}
log_action() {
    mkdir -p "$(dirname "$LOGFILE")"
    echo "$(date '+%Y-%m-%d %H:%M:%S') $*" >> "$LOGFILE"
}

load_pkg() {
    local pkg="$1"
    local conf="$PKGDIR/${pkg}.conf"
    [ -f "$conf" ] || die "No package definition for '$pkg' (looked in $PKGDIR)"
    # Reset all vars before sourcing
    PKG_NAME="" PKG_VER="" PKG_PREFIX="" PKG_BUILD_TYPE="" PKG_TARBALL="" PKG_CASCADE_SKIP="" PKG_STRIP_COMPONENTS=""
    PKG_URL1="" PKG_URL2="" PKG_URL3=""
    PKG_OPTS="" PKG_CMAKE_OPTS="" PKG_MESON_OPTS="" PKG_CARGO_OPTS=""
    PKG_PRE_BUILD="" PKG_POST_INSTALL="" PKG_CUSTOM_BUILD="" PKG_CUSTOM_INSTALL="" PKG_SKIP_AUTOGEN="" PKG_SKIP_EXTRACT=""
    # shellcheck source=/dev/null
    source "$conf"
    [ -n "$PKG_NAME" ] || die "PKG_NAME not set in $conf"
    [ -n "$PKG_VER"  ] || die "PKG_VER not set in $conf"
    [ -n "$PKG_URL1" ] || die "PKG_URL1 not set in $conf"
}

download_source() {
    local dest="$1"
    local urls=("$PKG_URL1" "${PKG_URL2:-}" "${PKG_URL3:-}")
    local attempt=0
    # Use cached tarball if already in /sources
    if [ -f "$dest" ]; then
        info "Using cached source: $(basename "$dest")"
        return 0
    fi
    for url in "${urls[@]}"; do
        [ -z "$url" ] && continue
        (( attempt++ )) || true
        info "Download attempt $attempt: $url"
        if wget -q --show-progress --timeout=30 --tries=2 \
                -O "${dest}.partial" "$url" 2>&1; then
            mv "${dest}.partial" "$dest"
            ok "Downloaded: $(basename "$dest")"
            return 0
        fi
        warn "Failed (attempt $attempt): $url"
        rm -f "${dest}.partial"
    done
    die "All $attempt download URL(s) failed for ${PKG_NAME}-${PKG_VER}"
}

detect_build() {
    # Honour explicit override from conf
    [ -n "$PKG_BUILD_TYPE" ] && { echo "$PKG_BUILD_TYPE"; return; }
    if   [ -f "CMakeLists.txt" ];                        then echo "cmake"
    elif [ -f "meson.build" ];                           then echo "meson"
    elif [ -f "configure" ];                             then echo "autotools"
    elif [ -f "configure.ac" ] || [ -f "configure.in" ]; then echo "autotools_gen"
    elif [ -f "Cargo.toml" ];                            then echo "cargo"
    else die "Cannot detect build system in $(pwd)"
    fi
}

build_autotools() {
    step "autotools build: configure → make → porg install"
    [ -f "autogen.sh" ] && [ -z "$PKG_SKIP_AUTOGEN" ] && { info "Running autogen.sh..."; run bash autogen.sh; }
    
    run ./configure --prefix="${PKG_PREFIX:-/usr}" ${PKG_OPTS}
    run make -j"$(nproc)"
    local s="/tmp/bogartpkg-inst-$$.sh"
    printf '#!/bin/sh\ncd %s\nmake install\n' "$builddir" > "$s"; chmod +x "$s"
    porg -lp "${PKG_NAME}-${PKG_VER}" "$s"; rm -f "$s"
}
build_cmake() {
    step "cmake build: configure → build → porg install"
    
    run cmake -B build \
        -DCMAKE_INSTALL_PREFIX="${PKG_PREFIX:-/usr}" \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_TESTING=OFF \
        ${PKG_CMAKE_OPTS}
    run cmake --build build --parallel "${PKG_JOBS:-$(nproc)}"
    local s="/tmp/bogartpkg-inst-$$.sh"
    printf '#!/bin/sh\ncd %s\ncmake --install build\n' "$builddir" > "$s"; chmod +x "$s"
    porg -lp "${PKG_NAME}-${PKG_VER}" "$s"; rm -f "$s"
}
build_meson() {
    step "meson build: setup → ninja → porg install"
    
    run meson setup build \
        --prefix="${PKG_PREFIX:-/usr}" \
        --buildtype=release \
        ${PKG_MESON_OPTS}
    run ninja -C build -j"$(nproc)"
    local s="/tmp/bogartpkg-inst-$$.sh"
    printf '#!/bin/sh\ncd %s\nninja -C build install\n' "$builddir" > "$s"; chmod +x "$s"
    porg -lp "${PKG_NAME}-${PKG_VER}" "$s"; rm -f "$s"
}
build_cargo() {
    step "cargo build: build --release → porg install"
    
    run cargo build --release ${PKG_CARGO_OPTS}
    local prefix="${PKG_PREFIX:-/usr}"
    local s="/tmp/bogartpkg-inst-$$.sh"
    echo "#!/bin/sh" > "$s"
    echo "cargo install --path . --root $prefix --no-track" >> "$s"
    chmod +x "$s"
    porg -lp "${PKG_NAME}-${PKG_VER}" "$s"; rm -f "$s"
}
build_custom() {
    step "custom build: PKG_CUSTOM_BUILD → PKG_CUSTOM_INSTALL → porg"
    [ -n "$PKG_CUSTOM_BUILD" ]   || die "PKG_BUILD_TYPE=custom but PKG_CUSTOM_BUILD not set"
    [ -n "$PKG_CUSTOM_INSTALL" ] || die "PKG_BUILD_TYPE=custom but PKG_CUSTOM_INSTALL not set"
    # Build step
    cd "$builddir"
    eval "$PKG_CUSTOM_BUILD" || return 1
    # Write install to a temp script so porg can wrap it cleanly
    local install_script="/tmp/bogartpkg-install-$$.sh"
    cat > "$install_script" << INSTALL_EOF
#!/bin/sh
cd '$builddir'
$PKG_CUSTOM_INSTALL
INSTALL_EOF
    chmod +x "$install_script"
    porg -lp "${PKG_NAME}-${PKG_VER}" "$install_script"
    local rc=$?
    rm -f "$install_script"
    return $rc
}
is_installed() {
    porg -i "${PKG_NAME}-${PKG_VER}" &>/dev/null
}

cmd_install() {
    local force=""
    local pkg=""
    
    for arg in "$@"; do
        case "$arg" in
            --force)    force="yes" ;;
            --dry-run)  DRYRUN="yes" ;;
            *)          pkg="$arg"  ;;
        esac
    done
    [ -n "$pkg" ] || die "Usage: bogartpkg install <pkg> [--force] [--dry-run]"
    require_root
    load_pkg "$pkg"
    [ -n "$DRYRUN" ] && warn "Dry Run (nothing will be built or installed)"
    info "Package: ${PKG_NAME}-${PKG_VER}"
    info "Prefix:  ${PKG_PREFIX:-/usr}"
    
    if is_installed && [ -z "$force" ] && [ -z "$DRYRUN" ]; then
        warn "${PKG_NAME}-${PKG_VER} is already installed. Use --force to rebuild."
        exit 0
    fi
    [ -n "$DRYRUN" ] && is_installed && \
        warn "${PKG_NAME}-${PKG_VER} already installed — dry run shows what --force would do"
    
    local tarball
    tarball="${PKG_TARBALL:-$(basename "$PKG_URL1")}"
    local srctar="${SRCDIR}/${tarball}"
    builddir="${BUILDROOT}/${PKG_NAME}-${PKG_VER}"

    if [ -n "$DRYRUN" ]; then
        if [ -f "$srctar" ]; then
            info "Source cached: $srctar"
        else
            dry "wget $PKG_URL1 → $srctar"
            [ -n "$PKG_URL2" ] && dry "  fallback URL2: $PKG_URL2"
            [ -n "$PKG_URL3" ] && dry "  fallback URL3: $PKG_URL3"
        fi
    else
        mkdir -p "$BUILDROOT"
        download_source "$srctar"
    fi
    
    step "Extracting to $builddir ..."
    if [ -n "$DRYRUN" ]; then
        dry "  mkdir -p $builddir"
        dry "  tar xf $srctar -C $builddir --strip-components=${PKG_STRIP_COMPONENTS:-1}"
    else
        rm -rf "$builddir"
        rm -rf "${SRCDIR}/${PKG_NAME}-${PKG_VER}"
        mkdir -p "$builddir"
        if [ -z "${PKG_SKIP_EXTRACT:-}" ]; then
            tar xf "$srctar" -C "$builddir" \
                --strip-components="${PKG_STRIP_COMPONENTS:-1}" || \
                die "Failed to extract $srctar"
        else
            cp "$srctar" "$builddir/"
        fi
    fi
    if [ -z "$DRYRUN" ]; then
        cd "$builddir"
    fi
    
    if [ -n "$PKG_PRE_BUILD" ]; then
        step "Pre-build hook:"
        if [ -n "$DRYRUN" ]; then
            dry "$PKG_PRE_BUILD"
        else
            eval "$PKG_PRE_BUILD"
        fi
    fi
    
    local backup_dir=""
    local old_porg_name=""
    if [ -z "$DRYRUN" ]; then
        old_porg_name=$(ls /var/lib/porg/ 2>/dev/null \
            | grep -E "^${PKG_NAME}-[0-9]" | tail -1 || true)
        if [ -n "$old_porg_name" ]; then
            backup_dir="${BUILDROOT}/.backup-${old_porg_name}"
            step "Backing up ${old_porg_name} → $backup_dir ..."
            rm -rf "$backup_dir"
            mkdir -p "$backup_dir"
            local backed_up=0
            while IFS= read -r f; do
                [ -f "$f" ] || [ -L "$f" ] || continue
                local dest="${backup_dir}${f}"
                mkdir -p "$(dirname "$dest")"
                cp -a "$f" "$dest" 2>/dev/null && (( backed_up++ )) || true
            done < <(porg -f "$old_porg_name" 2>/dev/null | grep "^/")
            info "Backed up $backed_up files from ${old_porg_name}"
        fi
    fi
    
    rollback() {
        if [ -n "$backup_dir" ] && [ -d "$backup_dir" ]; then
            warn "Install failed — rolling back ${old_porg_name}..."
            # Remove partially installed new pkg from porg db
            porg -rv "${PKG_NAME}-${PKG_VER}" 2>/dev/null || true
            # Restore old files
            cp -a "${backup_dir}/." / 2>/dev/null || true
            # Re-log old package from backup file list
            warn "Rollback complete — ${old_porg_name} restored from backup"
            rm -rf "$backup_dir"
            ldconfig
        fi
        rm -rf "$builddir"
        exit 1
    }
    
    local build_type
    if [ -n "$DRYRUN" ]; then
        if [ -n "$PKG_BUILD_TYPE" ]; then
            build_type="$PKG_BUILD_TYPE"
        else
            build_type="(auto-detect at build time)"
        fi
        info "Build system: $build_type"
    else
        build_type="$(detect_build)"
        info "Detected build system: $build_type"
    fi
    
    if [ -z "$DRYRUN" ]; then
        trap rollback ERR
        case "$build_type" in
            autotools|autotools_gen) build_autotools ;;
            cmake)                   build_cmake     ;;
            meson)                   build_meson     ;;
            cargo)                   build_cargo     ;;
            custom)                  build_custom    ;;
            *) die "Unknown build type: $build_type" ;;
        esac
        trap - ERR
    else
        if [ "$build_type" = "custom" ]; then
            dry "custom build: $PKG_CUSTOM_BUILD"
            dry "porg -lp ${PKG_NAME}-${PKG_VER} \"$PKG_CUSTOM_INSTALL\""
        else
            dry "./configure --prefix=${PKG_PREFIX:-/usr} ${PKG_OPTS}"
            [ -n "$PKG_CMAKE_OPTS" ] && dry "cmake opts: ${PKG_CMAKE_OPTS}"
            [ -n "$PKG_MESON_OPTS" ] && dry "meson opts: ${PKG_MESON_OPTS}"
            dry "make/ninja/cargo -j$(nproc)"
            dry "porg -lp ${PKG_NAME}-${PKG_VER} <install>"
        fi
    fi
    
    if [ -n "$PKG_POST_INSTALL" ]; then
        step "Post-install hook:"
        if [ -n "$DRYRUN" ]; then
            dry "$PKG_POST_INSTALL"
        else
            trap rollback ERR
            eval "$PKG_POST_INSTALL"
            trap - ERR
        fi
    fi
    
    step "Post-install: ldconfig + rebuild-deps --rescan $PKG_NAME"
    run ldconfig
    run rebuild-deps --rescan "$PKG_NAME"
    
    if [ -z "$DRYRUN" ] && [ -n "$old_porg_name" ] \
        && [ "$old_porg_name" != "${PKG_NAME}-${PKG_VER}" ]; then
        step "Removing old porg entry: $old_porg_name"
        porg -dv "$old_porg_name" 2>/dev/null || true
        bogartgraph --rescan "$PKG_NAME" 2>/dev/null || true
    fi
    
    [ -n "$backup_dir" ] && rm -rf "$backup_dir"
    step "Cleanup: rm -rf $builddir"
    run rm -rf "$builddir"
    ok "${PKG_NAME}-${PKG_VER} installed successfully."
    [ -z "$DRYRUN" ] && log_action "INSTALL ${PKG_NAME}-${PKG_VER}"
}
cmd_remove() {
    local pkg="$1"
    [ -n "$pkg" ] || die "Usage: bogartpkg remove <pkg>"
    require_root
    load_pkg "$pkg"
    porg -rv "${PKG_NAME}-${PKG_VER}"
    ldconfig
    ok "${PKG_NAME}-${PKG_VER} removed."
    log_action "REMOVE ${PKG_NAME}-${PKG_VER}"
}
cmd_info() {
    local pkg="$1"
    [ -n "$pkg" ] || die "Usage: bogartpkg info <pkg>"
    load_pkg "$pkg"
    printf "%-16s %s\n" "Name:"    "$PKG_NAME"
    printf "%-16s %s\n" "Version:" "$PKG_VER"
    printf "%-16s %s\n" "Prefix:"  "${PKG_PREFIX:-/usr}"
    printf "%-16s %s\n" "URL1:"    "$PKG_URL1"
    printf "%-16s %s\n" "URL2:"    "${PKG_URL2:-<none>}"
    printf "%-16s %s\n" "URL3:"    "${PKG_URL3:-<none>}"
    printf "%-16s %s\n" "Opts:"    "${PKG_OPTS:-<none>}"
    printf "%-16s %s\n" "CMakeOpts:"  "${PKG_CMAKE_OPTS:-<none>}"
    printf "%-16s %s\n" "MesonOpts:"  "${PKG_MESON_OPTS:-<none>}"
    printf "%-16s %s\n" "Pre-build:"  "${PKG_PRE_BUILD:-<none>}"
    printf "%-16s %s\n" "Post-install:" "${PKG_POST_INSTALL:-<none>}"
    is_installed \
        && printf "%-16s %s\n" "Installed:" "YES" \
        || printf "%-16s %s\n" "Installed:" "no"
}
cmd_list() {
    local installed
    echo "Available packages:"
    echo "-------------------------"
    for f in "$PKGDIR"/*.conf; do
        [ -f "$f" ] || continue
        PKG_NAME="" PKG_VER=""
        source "$f"
        installed=""
        is_installed 2>/dev/null && installed=" [installed]"
        printf "  %-30s %s%s\n" "$PKG_NAME" "$PKG_VER" "$installed"
    done
}
cmd_cascade() {
    set +euo pipefail
    local pkg=""
    for arg in "$@"; do
        case "$arg" in
            --dry-run) DRYRUN="yes" ;;
            *)         pkg="$arg"   ;;
        esac
    done
    [ -n "$pkg" ] || die "Usage: bogartpkg cascade <pkg> [--dry-run]"
    require_root
    load_pkg "$pkg"
    [ -n "$DRYRUN" ] && warn "Dry Run (nothing will be built)"
    info "Building cascade for ${PKG_NAME}..."    
    local sonames=()
    while IFS= read -r f; do
        [ -f "$f" ] || continue
        local sn
        sn=$(readelf -d "$f" 2>/dev/null \
            | awk '/SONAME/{gsub(/[\[\]]/,"",$NF); print $NF}')
        [ -n "$sn" ] && sonames+=("$sn")
    done < <(porg -f "${PKG_NAME}-${PKG_VER}" 2>/dev/null | grep '\.so' || true)
    if [ ${#sonames[@]} -eq 0 ]; then
        if [ -n "$PKG_MANUAL_CASCADE" ]; then
            info "No sonames found — using PKG_MANUAL_CASCADE: $PKG_MANUAL_CASCADE"
            declare -A seen_deps
            local deps=()
            for dep in $PKG_MANUAL_CASCADE; do
                seen_deps[$dep]=1
                deps+=("$dep")
            done
        else
            warn "No sonames found for ${PKG_NAME}-${PKG_VER} — nothing to cascade"
            return 0
        fi
    fi
    if [ ${#sonames[@]} -gt 0 ]; then
    local unique_sonames=()
    declare -A seen_sn
    for sn in "${sonames[@]}"; do
        [ -z "${seen_sn[$sn]+x}" ] && { seen_sn[$sn]=1; unique_sonames+=("$sn"); }
    done
    sonames=("${unique_sonames[@]}")
    info "Sonames provided: ${sonames[*]}"
    # Find unique dependents via bogartgraph
    declare -A seen_deps
    local deps=()
    while IFS= read -r dep; do
        if [ -n "$dep" ] && [ -z "${seen_deps[$dep]+x}" ] \
                         && [ "$dep" != "$PKG_NAME" ]; then
            seen_deps[$dep]=1
            deps+=("$dep")
        fi
    done < <(bogartgraph --rdeps "$PKG_NAME" 2>/dev/null | grep -v '^Packages\|^No sonames' | sed 's/^[[:space:]]*//')
    if [ ${#deps[@]} -eq 0 ]; then
        info "No dependents found — nothing to rebuild."
        return 0
    fi
    fi
    # topo-sorted order via bogartgraph
    local ordered=()
    while IFS= read -r dep; do
        [ -n "$dep" ] && ordered+=("$dep")
    done < <(bogartgraph --cascade "$PKG_NAME" 2>/dev/null | grep -E '^\s+[0-9]+\.' | sed 's/^[[:space:]]*[0-9]*\.[[:space:]]*//')
    #  print plan 
    echo ""
    info "Cascade rebuild order (${#ordered[@]} packages):"
    for i in "${!ordered[@]}"; do
        local conf_status=""
        local skip_flag=""
        if [ ! -f "$PKGDIR/${ordered[$i]}.conf" ]; then
            conf_status=" ${YLW}[no conf]${NC}"
        else
            skip_flag=$(bash -c "source $PKGDIR/${ordered[$i]}.conf 2>/dev/null; echo \${PKG_CASCADE_SKIP:-}")
            [ -n "$skip_flag" ] && conf_status=" ${YLW}[cascade skip: ${skip_flag}]${NC}"
        fi
        printf "  %3d. %-30s%b\n" "$((i+1))" "${ordered[$i]}" "$conf_status"
    done
    echo ""
    [ -n "$DRYRUN" ] && { dry "Dry run — no packages built."; return 0; }
    # build each in order 
    local built=0 skipped=0
    local failed=()
    for dep in "${ordered[@]}"; do
        if [ ! -f "$PKGDIR/${dep}.conf" ]; then
            warn "Skipping ${dep} — no conf in $PKGDIR"
            (( skipped++ )) || true
            continue
        fi
        local skip_flag=""
        skip_flag=$(bash -c "source $PKGDIR/${dep}.conf 2>/dev/null; echo \${PKG_CASCADE_SKIP:-}")
        if [ -n "$skip_flag" ]; then
            warn "Skipping ${dep} — PKG_CASCADE_SKIP set (${skip_flag})"
            (( skipped++ )) || true
            continue
        fi
        info "--- Rebuilding: $dep ---"
        if BOGARTPKG_CHILD=1 bogartpkg install "$dep" --force; then
            (( built++ )) || true
        else
            warn "FAILED: $dep"
            failed+=("$dep")
        fi
    done
    echo ""
    if [ ${#failed[@]} -gt 0 ]; then
        ok "Cascade complete: $built rebuilt, ${#failed[@]} failed, $skipped skipped (no conf or cascade-skip)"
        echo -e "${RED}FAILED:${NC}"
        for f in "${failed[@]}"; do
            echo -e "  ${RED}✗${NC} $f — see $LOGFILE"
        done
    else
        ok "Cascade complete: $built rebuilt, $skipped skipped (no conf or cascade-skip)"
    fi
    log_action "CASCADE ${PKG_NAME}-${PKG_VER} → ${ordered[*]}"
}
usage() {
    cat <<EOF
Bogart Linux Package Manager

Usage:
  bogartpkg install <pkg> [--force] [--dry-run]   Download, build, and porg-log a package
  bogartpkg remove  <pkg>                  	  Remove a package via porg -rv
  bogartpkg info    <pkg>             		  Show package definition and install status
  bogartpkg cascade <pkg> [--dry-run]        	  Rebuild all dependents in topo-sorted order
  bogartpkg list                     		  List all available packages

Build staging: $BUILDROOT
Package defs:  $PKGDIR
Source cache:  $SRCDIR
Log:           $LOGFILE
EOF
}

[ $# -lt 1 ] && { usage; exit 1; }
CMD="$1"; shift
case "$CMD" in
    install)
        mkdir -p "$(dirname "$LOGFILE")"
        [[ -z "${BOGARTPKG_CHILD:-}" ]] && exec > >(tee -a "$LOGFILE") 2>&1
        echo "--- bogartpkg install $* — $(date '+%Y-%m-%d %H:%M:%S') ---"
        cmd_install "$@"
        ;;
    remove)
        mkdir -p "$(dirname "$LOGFILE")"
        exec > >(tee -a "$LOGFILE") 2>&1
        echo "--- bogartpkg remove $1 — $(date '+%Y-%m-%d %H:%M:%S') ---"
        cmd_remove "$1"
        ;;
    cascade)
        mkdir -p "$(dirname "$LOGFILE")"
        echo "--- bogartpkg cascade $* — $(date '+%Y-%m-%d %H:%M:%S') ---" >> "$LOGFILE"
        cmd_cascade "$@" 
        ;;
    info)    cmd_info    "$1" ;;
    list)    cmd_list         ;;
    -h|--help|help) usage     ;;
    *) die "Unknown command: $CMD. Run 'bogartpkg --help' for usage." ;;
esac
