#!/bin/bash
# cpan-info — fetch latest version and download URL for a CPAN module
# Usage: cpan-info <Module-Name>

[[ $EUID -ne 0 ]] && { echo "Run as root."; exit 1; }
[[ -z "$1" ]] && { echo "Usage: cpan-info <Module-Name>"; exit 1; }

MODULE="$1"
DATA=$(curl -s "https://fastapi.metacpan.org/v1/release/${MODULE}")

if [[ -z "$DATA" ]]; then
    echo "Error: no data returned for '${MODULE}'"
    exit 1
fi

AUTHOR=$(echo "$DATA" | grep -oP '"author"\s*:\s*"\K[^"]+' | head -1)
VERSION=$(echo "$DATA" | grep -oP '"version"\s*:\s*"?\K[0-9][^",]+' | tail -1)
URL=$(echo "$DATA" | grep -oP '"download_url"\s*:\s*"\K[^"]+')

echo "Module  : ${MODULE}"
echo "Author  : ${AUTHOR}"
echo "Version : ${VERSION}"
echo "URL     : ${URL}"
